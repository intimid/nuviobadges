  "filters": [
    {
      "id": "seadex",
      "groupId": "special-tags",
      "name": "SeaDex",
      "pattern": "(?i)(?:\\bseadex\\b|ᴀʟᴛ\\s+ʀᴇʟᴇᴀsᴇ|ʙᴇsᴛ\\s+ʀᴇʟᴇᴀsᴇ|alt\\s+release|best\\s+release)",
      "imageURL": "https://raw.githubusercontent.com/intimid/nuviobadges/main/BadgeIcons/seadex.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#00000000",
      "tagStyle": "filled and bordered",
      "isEnabled": true,
      "type": "filter"
    }, 
    {
      "id": "blu-ray-disc",
      "groupId": "source",
      "name": "Blu-ray Disc",
      "pattern": "(?i)^(?=.*\\b(?:blu[-_. ]?ray|b[rd][-_. ]?rip)\\b)(?!.*\\bremux\\b)",
      "imageURL": "https://raw.githubusercontent.com/intimid/nuviobadges/main/BadgeIcons/bluray.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#00000000",
      "tagStyle": "filled and bordered",
      "isEnabled": true,
      "type": "filter"
    },
    {
      "id": "imax-enhanced",
      "groupId": "imax",
      "name": "IMAX Enhanced",
      "pattern": "(?i)\\bimax[\\s._-]?enhanced\\b",
      "imageURL": "https://raw.githubusercontent.com/leonevz/Elite-Badges/main/Badges/imax_enhanced.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#00000000",
      "tagStyle": "filled and bordered",
      "isEnabled": true,

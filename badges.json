      "pattern": "(?i)^(?!.*\\b(?:dv|dovi|dolby[\\s._-]?vision)\\b)(?=.*\\bhdr[\\s._-]?10\\b)(?!.*\\bhdr[\\s._-]?10[\\s._-]?(?:\\+|plus|p)(?:\\b|[^a-z0-9]))",
